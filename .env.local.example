# CDBS Config
# Free mode: use Google Sheets as the main database and Google Drive for files.
# Falls back to browser localStorage for local testing when Google env is missing.
NEXT_PUBLIC_CDBS_PROVIDER="google-sheets"
NEXT_PUBLIC_CDBS_LOCAL_STORAGE_KEY="artclass_media_v2"

# Google Service Account (Private - Server Side ONLY)
# Do NOT prefix with NEXT_PUBLIC_
# Put the service account email here, not the full JSON file.
GOOGLE_SERVICE_ACCOUNT_EMAIL="YOUR_SERVICE_ACCOUNT_EMAIL"
GOOGLE_PRIVATE_KEY="YOUR_PRIVATE_KEY_INCLUDING_BEGIN_AND_END_PRIVATE_KEY"

# Target Destinations
GOOGLE_DRIVE_FOLDER_ID="YOUR_DRIVE_FOLDER_ID"
GOOGLE_SHEETS_SPREADSHEET_ID="YOUR_SPREADSHEET_ID"
GOOGLE_SHEETS_MEDIA_SHEET_NAME="Media"
GOOGLE_SHEETS_ACADEMIC_SHEET_NAME="AcademicWorks"
